{
  "name": "watercolor",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "format": "biome check . --write",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "generate:component": "turbo run generate:component --filter=./packages/ui",
    "export:component": "turbo run export:component --filter=./packages/ui",
    "generate:shadcn": "turbo run generate:shadcn --filter=./packages/ui"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@biomejs/biome": "1.9.4",
    "@storybook/addons": "^7.6.17",
    "turbo": "^2.2.3",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
